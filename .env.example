# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/takovic?sslmode=require
# After migrate: npm run db:seed:market-equities — loads data/market-equities/universe.csv into market_equities

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Yahoo Finance (via yahoo-finance2 — no API key required)

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-key

# Auth.js
AUTH_SECRET=your-auth-secret
AUTH_GOOGLE_ID=your-google-oauth-id
AUTH_GOOGLE_SECRET=your-google-oauth-secret
AUTH_GITHUB_ID=your-github-oauth-id
AUTH_GITHUB_SECRET=your-github-oauth-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin dashboard (/admin) — read by Node server (layout + login API), not Edge
# On Vercel: enable for Production (and Preview if you use preview URLs), then redeploy
ADMIN_DASHBOARD_SECRET=
NEXT_PUBLIC_SHOW_ADMIN=
